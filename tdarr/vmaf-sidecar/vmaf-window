#!/usr/bin/env python3
"""Whole-file VMAF gate, invoked by the Tdarr worker plugin.

Usage: vmaf-window <src> <out>

Computes libvmaf over the entire file (no seeking) with PTS-based
framesync, so VFR / dropped-frame encodes don't desync the comparison.
Prints one JSON line on stdout:

  {"verdict":"pass","vmaf":96.92,"seconds":312.4,"algorithm":"full_v2"}

Exit code 0 on a clean run regardless of verdict (pass / fail / error_*).
Non-zero only if argv is wrong or ffprobe can't even start.

Why whole-file instead of 3 windows: input-seek on both files
independently lands on different source moments when libsvtav1
collapses duplicate frames (Black Clover S1: 34377 src frames vs
34138 AV1 frames over an identical 1435s duration). PTS framesync
aligns by timestamp, not frame index. ~10x slower than the windowed
approach but correct. See architecture/libvmaf-measurement-gotchas
in the knowledge vault for the broader set of traps.
"""
import json
import os
import re
import subprocess
import sys
import time

FFMPEG = os.environ.get("FFMPEG", "/sidecar/bin/ffmpeg")
FFPROBE = os.environ.get("FFPROBE", "/sidecar/bin/ffprobe")
VMAF_MIN = float(os.environ.get("VMAF_MIN", "95.0"))
VMAF_THREADS = int(os.environ.get("VMAF_THREADS", "4"))
ALGORITHM = "full_v2"

VMAF_RE = re.compile(r"VMAF score:\s*([0-9.]+)")


def probe_duration(path):
    r = subprocess.run(
        [FFPROBE, "-v", "error", "-show_entries", "format=duration",
         "-of", "csv=p=0", path],
        capture_output=True, text=True,
    )
    try:
        return float(r.stdout.strip())
    except ValueError:
        return None


def vmaf_full(src, out):
    cmd = [
        FFMPEG, "-nostdin", "-hide_banner",
        "-i", out,
        "-i", src,
        "-an", "-sn",
        "-lavfi",
        "[0:v]format=yuv420p10le[dist];"
        "[1:v]format=yuv420p10le[ref];"
        f"[dist][ref]libvmaf=pool=mean:n_threads={VMAF_THREADS}",
        "-f", "null", "-",
    ]
    r = subprocess.run(cmd, capture_output=True, text=True)
    m = VMAF_RE.search(r.stderr)
    return (float(m.group(1)) if m else None, r.stderr[-1500:])


def main():
    if len(sys.argv) != 3:
        print("usage: vmaf-window <src> <out>", file=sys.stderr)
        return 2
    src, out = sys.argv[1], sys.argv[2]
    rec = {"src": src, "out": out, "algorithm": ALGORITHM}
    t0 = time.time()
    duration = probe_duration(src)
    if duration is None or duration < 30:
        rec.update(verdict="error_duration", duration=duration,
                   seconds=round(time.time() - t0, 1))
        print(json.dumps(rec))
        return 0
    v, err = vmaf_full(src, out)
    if v is None:
        rec.update(verdict="error_vmaf", error_tail=err,
                   seconds=round(time.time() - t0, 1))
        print(json.dumps(rec))
        return 0
    rec["vmaf"] = round(v, 3)
    rec["verdict"] = "pass" if v >= VMAF_MIN else "fail"
    rec["seconds"] = round(time.time() - t0, 1)
    print(json.dumps(rec))
    return 0


if __name__ == "__main__":
    sys.exit(main())
